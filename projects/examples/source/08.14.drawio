        <mxCell id="vt7VQfZ9MeC5z4v0P5rx-5" parent="1" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=0;fontSize=12;" value="&lt;font&gt;&lt;span&gt;&amp;nbsp;Z&amp;nbsp;=&amp;nbsp;X * Y = A&amp;nbsp;* 10&lt;sup&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;2N&lt;/font&gt;&lt;/sup&gt; + (C - B - A) * 10&lt;sup&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;N&lt;/font&gt;&lt;/sup&gt; + B&lt;/span&gt;&lt;/font&gt;" vertex="1">
